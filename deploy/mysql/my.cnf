# MySQL 8.0 自定义配置（MyRAG 项目）
# 挂载路径：/etc/mysql/conf.d/myrag.cnf
#
# 面试考点：
#   innodb_buffer_pool_size  — InnoDB 缓冲池，缓存数据和索引页，是 MySQL 最重要的性能参数
#                              建议设为物理内存的 50%~70%，此处 256M 适合开发环境
#   max_connections          — 最大并发连接数，需与应用连接池 pool_size + max_overflow 匹配
#   slow_query_log           — 慢查询日志，记录超过 long_query_time 的 SQL，用于性能分析
#   innodb_log_file_size     — Redo Log 大小，影响写入性能和崩溃恢复时间

[mysqld]
# 字符集（必须与建表时的 charset 一致）
character-set-server        = utf8mb4
collation-server            = utf8mb4_unicode_ci
init-connect                = 'SET NAMES utf8mb4'

# InnoDB 存储引擎优化
innodb_buffer_pool_size     = 256M
innodb_log_file_size        = 64M
innodb_flush_log_at_trx_commit = 1   # 1=最安全（每次提交刷盘），2=性能优先（每秒刷盘）

# 连接配置
max_connections             = 200
wait_timeout                = 28800   # 空闲连接超时 8h（应用 pool_recycle 需小于此值）
interactive_timeout         = 28800

# 慢查询日志（开发环境开启，生产环境按需）
slow_query_log              = 1
slow_query_log_file         = /var/log/mysql/slow.log
long_query_time             = 1       # 超过 1 秒记录为慢查询

# 时区（与应用保持一致）
default-time-zone           = '+08:00'

[client]
default-character-set       = utf8mb4

[mysql]
default-character-set       = utf8mb4
