{
  "dashboard": {
    "title": "MyRAG - RAG System Dashboard",
    "description": "面试考点：Grafana Dashboard 配置、Prometheus 数据源、PromQL 查询语法",
    "panels": [
      {
        "title": "请求 QPS",
        "type": "graph",
        "targets": [
          {"expr": "rate(rag_request_total[5m])", "legendFormat": "{{method}} {{endpoint}}"}
        ]
      },
      {
        "title": "请求延迟 P95",
        "type": "graph",
        "targets": [
          {"expr": "histogram_quantile(0.95, rate(rag_request_duration_seconds_bucket[5m]))", "legendFormat": "p95"}
        ]
      },
      {
        "title": "LLM Token 使用量",
        "type": "graph",
        "targets": [
          {"expr": "rate(rag_llm_token_total[5m])", "legendFormat": "{{type}}"}
        ]
      },
      {
        "title": "语义缓存命中率",
        "type": "gauge",
        "targets": [
          {"expr": "rag_cache_hit_total / (rag_cache_hit_total + rag_cache_miss_total)", "legendFormat": "hit_ratio"}
        ]
      },
      {
        "title": "检索文档数分布",
        "type": "histogram",
        "targets": [
          {"expr": "rag_retrieval_documents_bucket", "legendFormat": "{{le}}"}
        ]
      },
      {
        "title": "文档处理耗时",
        "type": "graph",
        "targets": [
          {"expr": "histogram_quantile(0.95, rate(rag_document_processing_seconds_bucket[5m]))", "legendFormat": "p95"}
        ]
      },
      {
        "title": "FAISS 向量数量",
        "type": "stat",
        "targets": [
          {"expr": "rag_vector_store_size", "legendFormat": "vectors"}
        ]
      },
      {
        "title": "活跃 WebSocket 连接",
        "type": "stat",
        "targets": [
          {"expr": "rag_active_websocket_connections", "legendFormat": "connections"}
        ]
      },
      {
        "title": "评估指标",
        "type": "gauge",
        "targets": [
          {"expr": "rag_evaluation_score", "legendFormat": "{{metric}}"}
        ]
      }
    ]
  },
  "_comment": "面试时可以用这个 JSON 配置一键导入 Grafana，展示完整的监控看板"
}
