# ===== 应用配置 =====
APP_NAME=MyRAG
APP_VERSION=0.1.0
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ===== 数据库配置 =====
DATABASE_URL=sqlite+aiosqlite:///./data/myrag.db

# ===== LLM 配置 =====
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# ===== Embedding 配置 =====
# local: sentence-transformers 本地模型 | openai: OpenAI API
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512

# ===== 检索配置 =====
RETRIEVAL_TOP_K=5
RETRIEVAL_RRF_K=60
# 高级检索特性开关
RETRIEVAL_ENABLE_HYDE=false
RETRIEVAL_ENABLE_MULTI_QUERY=false
RETRIEVAL_ENABLE_CACHE=false
RETRIEVAL_CACHE_SIMILARITY_THRESHOLD=0.92
RETRIEVAL_CACHE_TTL_SECONDS=3600

# ===== 分块配置 =====
CHUNK_SIZE=512
CHUNK_OVERLAP=50
CHUNK_STRATEGY=recursive

# ===== 文件存储 =====
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE=52428800

# ===== 钉钉机器人配置 =====
DINGTALK_ENABLED=false
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
DINGTALK_SECRET=

# ===== 向量存储配置 =====
# provider: faiss（本地开发）| milvus（生产环境）
VECTOR_STORE_PROVIDER=faiss

# ── Milvus 私有化部署（VECTOR_STORE_PROVIDER=milvus 时生效）──
VECTOR_STORE_MILVUS_HOST=localhost
VECTOR_STORE_MILVUS_PORT=19530
VECTOR_STORE_MILVUS_USER=root
VECTOR_STORE_MILVUS_PASSWORD=Milvus
VECTOR_STORE_MILVUS_DB_NAME=default
VECTOR_STORE_MILVUS_COLLECTION=rag_chunks

# ── Zilliz Cloud（托管 Milvus，与上面二选一）──
# VECTOR_STORE_MILVUS_URI=https://in01-xxxx.api.gcp-us-west1.zillizcloud.com
# VECTOR_STORE_MILVUS_TOKEN=your-api-key

# ── Milvus 索引配置 ──
# 索引类型：HNSW（生产推荐）| IVF_FLAT（高精度）| IVF_SQ8（内存受限）
VECTOR_STORE_MILVUS_INDEX_TYPE=HNSW
# 相似度度量：IP（内积，适合归一化向量）| L2（欧氏距离）
VECTOR_STORE_MILVUS_METRIC_TYPE=IP
# HNSW 参数（M 越大精度越高但内存越多，建议 8~64）
VECTOR_STORE_MILVUS_HNSW_M=16
VECTOR_STORE_MILVUS_HNSW_EF_CONSTRUCTION=256
# 搜索时 ef（越大召回越准但越慢，建议 >= top_k * 2）
VECTOR_STORE_MILVUS_HNSW_EF_SEARCH=64

# ===== Redis 配置（Phase 2+） =====
# REDIS_URL=redis://localhost:6379/0
